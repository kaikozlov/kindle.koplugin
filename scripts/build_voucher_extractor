#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SOURCE="$REPO_ROOT/lib/KFXVoucherExtractor.java"
STUBS_DIR="$REPO_ROOT/lib/java-stubs"
OUTPUT="$REPO_ROOT/lib/KFXVoucherExtractor.jar"
BUILD_DIR="$(mktemp -d "${TMPDIR:-/tmp}/kindle-voucher-extractor.XXXXXX")"
trap 'rm -rf "$BUILD_DIR"' EXIT

mkdir -p "$BUILD_DIR/classes" "$BUILD_DIR/jar/META-INF"

# Compile against minimal API stubs. The actual SDK implementation is supplied
# by /opt/amazon/ebook/lib/YJReader-impl.jar on the Kindle at runtime.
stub_sources=()
while IFS= read -r stub_source; do
    stub_sources+=("$stub_source")
done < <(find "$STUBS_DIR" -name '*.java' -type f -print | sort)

javac --release 8 \
    -d "$BUILD_DIR/classes" \
    "${stub_sources[@]}" \
    "$SOURCE"

cp "$BUILD_DIR/classes/KFXVoucherExtractor.class" "$BUILD_DIR/jar/"
cp "$SOURCE" "$BUILD_DIR/jar/KFXVoucherExtractor.java"
printf 'Manifest-Version: 1.0\nMain-Class: KFXVoucherExtractor\n\n' \
    > "$BUILD_DIR/jar/META-INF/MANIFEST.MF"

rm -f "$OUTPUT"
(
    cd "$BUILD_DIR/jar"
    jar cfm "$OUTPUT" META-INF/MANIFEST.MF KFXVoucherExtractor.class KFXVoucherExtractor.java
)

echo "Built $OUTPUT"
