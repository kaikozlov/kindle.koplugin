#!/usr/bin/env bash
# Run Lua specs against the same real KOReader runtime used by make test and CI.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="ghcr.io/kaikozlov/koplugin-dev:v2026.03_7"

args=()
if (( $# == 0 )); then
    args=(/opt/plugin/spec/)
else
    for arg in "$@"; do
        if [[ "$arg" == spec/* ]]; then
            args+=("/opt/plugin/$arg")
        else
            args+=("$arg")
        fi
    done
fi

exec docker run --rm \
    -e SDL_VIDEODRIVER=dummy \
    -v "$ROOT_DIR:/opt/plugin" \
    -e PLUGIN_NAME=kindle \
    "$IMAGE" \
    busted-koreader --verbose \
        --helper=/opt/koplugin-dev/commonrequire.lua \
        --exclude-tags=e2e \
        "${args[@]}"
